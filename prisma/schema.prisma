datasource db {
  provider = "sqlite"
}

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native"]
}

model Project {
  id          String   @id @default(cuid())
  title       String
  expertIds   String
  status      String   @default("active")
  phase       String   @default("diverge")
  turnCount   Int      @default(0)
  currentSeq  Int      @default(0) // P3-1: 撤销/重做指针（0=最新，>0=已撤销到历史位置）
  createdAt   DateTime @default(now())
  completedAt DateTime?
  messages    Message[]
  documents   GeneratedDocument[]
  knowledgeEntries KnowledgeEntry[]
  snapshots   StateSnapshot[]

  @@index([status])
  @@index([createdAt])
}

model Message {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String
  content   String
  metadata  String?
  seq       Int
  createdAt DateTime @default(now())

  @@index([projectId, seq])
  @@index([projectId, createdAt])
}

model ExpertDefinition {
  id          String   @id @default(cuid())
  name        String
  avatarColor String   @default("emerald")
  persona     String
  focus       String
  isBuiltin   Boolean  @default(false)
  builtinId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isBuiltin])
}

model GeneratedDocument {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  docType   String
  content   String
  createdAt DateTime @default(now())

  @@index([projectId, docType])
}

model KnowledgeEntry {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category        String
  content         String
  sourceMessageId String?
  embedding       String?
  createdAt       DateTime @default(now())

  @@index([projectId])
}

model StateSnapshot {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  seq       Int
  state     String
  createdAt DateTime @default(now())

  @@index([projectId, seq])
}

model LLMCallLog {
  id           String   @id @default(cuid())
  model        String
  inputTokens  Int?
  outputTokens Int?
  durationMs   Int
  success      Boolean
  errorMessage String?
  projectId    String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([projectId])
  @@index([success])
}

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  title       String
  expertIds   String
  phase       String   @default("diverge")
  isBuiltin   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isBuiltin])
}

/// P2-3: 专家长期记忆 — 跨项目积累专家洞察/偏好/经验教训
model ExpertMemory {
  id        String   @id @default(cuid())
  expertId  String
  projectId String
  content   String
  embedding String?
  category  String   @default("insight") // insight | preference | lesson_learned
  createdAt DateTime @default(now())

  @@index([expertId])
  @@index([expertId, projectId])
  @@index([projectId])
}
