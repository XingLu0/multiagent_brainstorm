{
  "name": "ai-brainstorm",
  "version": "1.0.1",
  "private": true,
  "license": "MIT",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "start:prod": "npx kill-port 3000 && next start",
    "lint": "eslint",
    "kill-port": "npx kill-port 3000",
    "dev:clean": "npx kill-port 3000 && next dev -H 0.0.0.0",
    "setup": "npm install && node scripts/rebuild-sqlite.cjs && npx prisma generate && npx prisma db push && npx tsx prisma/seed.ts",
    "rebuild:sqlite": "node scripts/rebuild-sqlite.cjs",
    "electron:ts": "tsc -p electron/tsconfig.json",
    "electron:prepare": "node scripts/prepare-electron.cjs",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "electron:dev": "npm run electron:ts && npm run rebuild:node && concurrently -k -n NEXT,ELC \"next dev\" \"wait-on tcp:3000 && electron .\"",
    "electron:build": "npm run build && npm run electron:prepare && npm run electron:ts && electron-builder --win"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.74",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.62.0",
    "@sentry/react": "^10.62.0",
    "ai": "^6.0.208",
    "better-sqlite3": "^12.11.1",
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "xstate": "^5.32.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
